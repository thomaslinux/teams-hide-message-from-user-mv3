{
  "manifest_version": 2,
  "name": "Hide Teams Users Messages",
  "version": "1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "thomaslinux-teams-messages-hider@github.com"
    }
  },
  "description": "Hide messages from specific users in chat.",
  "permissions": ["storage", "activeTab"],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "options.html",
    "default_title": "Hide Teams Users Messages"
  },
  "content_scripts": [
    {
      "matches": ["https://teams.cloud.microsoft/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
